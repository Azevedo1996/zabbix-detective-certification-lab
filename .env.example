# Django
DJANGO_SECRET_KEY=troque-esta-chave
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,django
DJANGO_TIME_ZONE=America/Sao_Paulo
SQLITE_NAME=/app/data/db.sqlite3

# Zabbix API usada pelo Django dentro do Docker
ZABBIX_URL=http://zabbix-web:8080/api_jsonrpc.php
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix

# Banco do Zabbix Lab
POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=zabbix
PHP_TZ=America/Sao_Paulo

# Ajustes básicos do Zabbix Server
ZBX_STARTPOLLERS=5
ZBX_STARTPREPROCESSORS=3
ZBX_CACHESIZE=128M
ZBX_HISTORYCACHESIZE=64M
ZBX_TRENDCACHESIZE=32M
